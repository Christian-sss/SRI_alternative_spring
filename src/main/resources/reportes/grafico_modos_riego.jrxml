<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="grafico_modos_riego"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              uuid="b5c46e3d-1234-5678-abcd-ef9876543210">

    <parameter name="creadoPor" class="java.lang.String"/>

    <field name="modoRiego" class="sri.project.sri_project.model.enums.ModoRiego">
        <property name="net.sf.jasperreports.bean.field.property" value="modoRiego"/>
    </field>
    <field name="cantidad" class="java.lang.Long">
        <property name="net.sf.jasperreports.bean.field.property" value="cantidad"/>
    </field>

    <background>
        <band splitType="Stretch"/>
    </background>

    <title>
        <band height="79" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30" uuid="e3a2b1c0-5555-4444-bebe-1234567890ab"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[SISTEMA DE RIEGO INTELIGENTE (SRI)]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="45" width="555" height="20" uuid="f4b3c2a1-6666-4444-baba-0987654321ba"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="10" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Análisis de Modos de Riego del Mes Actual - " + $P{creadoPor}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="70" width="555" height="1" uuid="a1b2c3d4-e4e4-4f4f-afaf-112233445566"/>
            </line>
        </band>
    </title>

    <summary>
        <band height="350" splitType="Stretch">
            <pieChart>
                <chart evaluationTime="Report">
                    <reportElement x="40" y="20" width="480" height="300" uuid="c2d3e4f5-7777-4444-aaaa-aabbccddeeff"/>
                    <chartTitle>
                        <titleExpression><![CDATA["Proporción de Riegos: Manuales vs Automáticos"]]></titleExpression>
                    </chartTitle>
                    <chartSubtitle/>
                    <chartLegend position="Bottom"/>
                </chart>
                <pieDataset>
                    <dataset resetType="Report"/>
                    <keyExpression><![CDATA[$F{modoRiego}.name()]]></keyExpression>
                    <valueExpression><![CDATA[$F{cantidad}]]></valueExpression>
                    <labelExpression><![CDATA[$F{modoRiego}.name() + " (" + $F{cantidad} + ")"]]></labelExpression>
                </pieDataset>
                <piePlot isCircular="true">
                    <itemLabel/>
                </piePlot>
            </pieChart>
        </band>
    </summary>
</jasperReport>